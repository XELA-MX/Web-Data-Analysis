# ─────────────────────────────────────────────────────────────
# Variables de entorno del proyecto. COPIA este archivo a `.env`
# y rellena los valores reales. El `.env` real NUNCA se commitea.
# ─────────────────────────────────────────────────────────────

# Conexión a PostgreSQL (accesible vía Tailscale).
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
# HOST = IP de Tailscale (100.x.x.x) o nombre MagicDNS de la máquina con Postgres.
# Usado por el MCP de Postgres (variable DATABASE_URI).
DATABASE_URI=postgresql://admin:CAMBIAME@100.x.x.x:5432/jobmarket

# ─────────────────────────────────────────────────────────────
# Postgres LOCAL de docker-compose (para `docker compose up`).
# Independiente de la DB remota de arriba. Tienen defaults en el
# compose, pero defínelas aquí para un entorno local consistente.
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=jobmarket
POSTGRES_PASSWORD=CAMBIAME
POSTGRES_DB=jobmarket
POSTGRES_PORT=5432
